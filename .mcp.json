{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["--no-install", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["--no-install", "@modelcontextprotocol/server-filesystem", "./src"]
    }
  }
}
